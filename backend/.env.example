# LLM API 配置
# 将此文件复制为 .env，并填写你的实际值。
# 绝不要把 .env 提交到版本控制。

# OpenAI-compatible API key
LLM_API_KEY=sk-your-api-key-here

# OpenAI-compatible API base URL（可选，用于自定义 endpoint）
# 留空则使用默认的 OpenAI endpoint。
LLM_BASE_URL=https://api.openai.com/v1

# TTS API 配置（MiniMax，可选）
# 未设置 TTS_API_KEY 时，TTS 功能不可用，结局将仅有文本无语音。
# TTS_API_KEY=your-minimax-api-key-here
# TTS_WS_URL=wss://api.minimax.chat/ws/v1/t2a_v2

# 部署配置（可选）
# SERVER_PORT=8080
# CORS_ORIGINS=https://your-domain.example,http://localhost:5173
