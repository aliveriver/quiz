# 复制为 .env 后可被 docker compose 自动读取。
# 这里的端口是服务器宿主机对外暴露的端口。

# 前端容器绑定地址。
# 用服务器 Nginx 反代时建议只绑定 127.0.0.1，避免 Docker 服务直接暴露公网。
FRONTEND_HOST=127.0.0.1

# 服务器本机端口，外层 Nginx 会代理到 http://127.0.0.1:8088
FRONTEND_PORT=8088

# 后端容器内部监听端口，通常不需要改。
BACKEND_CONTAINER_PORT=8080

# 部署到 aliveriver.xyz/love/ 时使用 /love/
VITE_BASE_PATH=/love/

# 你的 aliveriver.xyz 已经占用 /api/，所以本项目 API 使用 /love-api/
VITE_API_BASE_URL=/love-api
